<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/push_page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_push_header"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="26dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/push_demo_title"
            android:textColor="@color/push_text_inverse"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/push_demo_subtitle"
            android:textColor="#D7E8FF"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_push_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/PushSectionTitle"
                    android:text="@string/push_section_push_id" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/push_push_id_desc"
                    android:textColor="@color/push_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/get_registration_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_push_log"
                    android:minHeight="72dp"
                    android:padding="12dp"
                    android:text="@string/push_empty_value"
                    android:textColor="@color/push_text_primary"
                    android:textIsSelectable="true"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_push_status_dot" />

                    <TextView
                        android:id="@+id/tv_register_state"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/push_status_idle"
                        android:textColor="@color/push_idle"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_sdk_app_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/push_text_secondary"
                        android:textSize="12sp"
                        android:textIsSelectable="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_copy_registration_id"
                        style="@style/PushButtonBase"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_push_primary_button"
                        android:text="@string/push_copy"
                        android:textColor="@color/push_text_inverse" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Button
                        style="@style/PushButtonBase"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_push_secondary_button"
                        android:onClick="getRegistrationId"
                        android:text="@string/push_refresh"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_push_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/PushSectionTitle"
                    android:text="@string/push_section_actions" />

                <EditText
                    android:id="@+id/registration_id"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_push_input"
                    android:hint="@string/push_registration_hint"
                    android:inputType="text"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:textColor="@color/push_text_primary"
                    android:textColorHint="@color/push_text_tertiary"
                    android:textSize="14sp" />

                <Button
                    style="@style/PushButtonBase"
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_push_secondary_button"
                    android:onClick="setRegistrationId"
                    android:text="@string/push_set_registration_id"
                    android:textColor="@color/colorPrimary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        style="@style/PushButtonBase"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_push_secondary_button"
                        android:onClick="registerTPush"
                        android:text="@string/push_register"
                        android:textColor="@color/colorPrimary" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Button
                        style="@style/PushButtonBase"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_push_secondary_button"
                        android:onClick="unRegisterTPush"
                        android:text="@string/push_unregister"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_push_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/PushSectionTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="@string/push_section_result" />

                    <TextView
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:minWidth="44dp"
                        android:text="@string/push_clear_result"
                        android:textColor="@color/push_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_push_log"
                    android:minHeight="56dp"
                    android:padding="12dp"
                    android:text="@string/push_result_empty"
                    android:textColor="@color/push_text_primary"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
